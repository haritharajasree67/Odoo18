<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_order_form_inherit_qty" model="ir.ui.view">
    <field name="name">sale.order.form.inherit.qty</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
        <xpath expr="//page[@name='order_lines']/field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
            <field name="qty_available" readonly="1" string="Qty On Hand" groups="product_qty_in_sales.group_order_qty_on_hand"/>
        </xpath>
    </field>
</record>

</odoo>