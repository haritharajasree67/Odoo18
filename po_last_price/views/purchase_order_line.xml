<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_purchase_order_line_inherit_last_price" model="ir.ui.view">
        <field name="name">purchase.order.line.inherit.last.price</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook/page[@name='products']//field[@name='price_unit']" position="before">
                <field name="last_purchase_price" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>