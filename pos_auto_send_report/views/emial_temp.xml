<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="pos_report_email_template" model="mail.template">
            <field name="name">POS Daily Report Email</field>
            <field name="model_id" ref="point_of_sale.model_pos_session"/>
            <field name="subject">Daily POS Report</field>
            <field name="body_html">
                <![CDATA[
                    <p>Hello,</p>
                    <p>Attached is the daily POS closing report.</p>
                    <p>Regards,<br/>POS System</p>
                ]]>
            </field>
            <field name="email_from">${(user.email_formatted or 'noreply@example.com')}</field>
        </record>
    </data>
</odoo>
